// §16.7 Mux tmux keymap profile: prefix key (Ctrl-b) + prefix-mode bindings
// spec §16.7, Plan 17 — tmux-compatible subset (~80% of common operations)
// NOTE: This is NOT 1:1 tmux compatibility; it covers the most common operations.
[
  // Normal mode: prefix key triggers prefix mode with 500ms timeout
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-b": ["mux::enterPrefixMode", { "timeout_ms": 500 }],

      // §12 复制模式 (Plan 31)
      "ctrl-shift-;": "terminal::EnterCopyMode"
    }
  },
  // Prefix mode: after Ctrl-b, the next key is matched here
  {
    "context": "Terminal && PrefixMode",
    "bindings": {
      // Tab management
      "c": "pane::newTab",
      "&": "pane::closeTab",
      "n": "pane::nextTab",
      "p": "pane::prevTab",

      // Pane splitting
      "%": "pane::splitRight",
      "\"": "pane::splitDown",

      // Pane navigation (directional)
      "left": "pane::focusLeft",
      "right": "pane::focusRight",
      "up": "pane::focusUp",
      "down": "pane::focusDown",
      "h": "pane::focusLeft",
      "j": "pane::focusDown",
      "k": "pane::focusUp",
      "l": "pane::focusRight",
      "o": "pane::focusNextPane",

      // Pane navigation (numbered)
      "0": "pane::focusPane0",
      "1": "pane::focusPane1",
      "2": "pane::focusPane2",
      "3": "pane::focusPane3",
      "4": "pane::focusPane4",
      "5": "pane::focusPane5",
      "6": "pane::focusPane6",
      "7": "pane::focusPane7",
      "8": "pane::focusPane8",

      // Pane resizing
      "ctrl-left": "pane::resizeLeft",
      "ctrl-right": "pane::resizeRight",
      "ctrl-up": "pane::resizeUp",
      "ctrl-down": "pane::resizeDown",

      // Pane zoom
      "z": "pane::zoomToggle",

      // Mux session
      "d": "mux::detach",

      // Send literal Ctrl-b to PTY (double-tap escape)
      "ctrl-b": "terminal::sendKeystroke Ctrl-b"
    }
  }
]
