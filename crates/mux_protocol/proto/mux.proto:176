// §3.10 重命名会话。
message RenameSessionRequest {
    string id = 1;
    string name = 2;
}

// §3.10 设置 Pane 标题。
message SetPaneTitleRequest {
    string pane_id = 1;
    string title = 2;
}

// §3.10 调整 Pane 尺寸。
message ResizePaneRequest {
    string pane_id = 1;
    uint32 cols = 2;
    uint32 rows = 3;
}
